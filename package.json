{
  "name": "kline-component",
  "version": "1.1.0",
  "description": "A high-performance React K-line (candlestick) chart component with Canvas rendering, 7 technical indicators, dark/light themes, zoom, pan, and crosshair.",
  "type": "module",
  "main": "./dist/kline-component.cjs",
  "module": "./dist/kline-component.js",
  "types": "./dist/src/kline/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/kline/index.d.ts",
      "import": "./dist/kline-component.js",
      "require": "./dist/kline-component.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "cd example && npm run dev",
    "lint": "eslint src/",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kline",
    "candlestick",
    "chart",
    "react",
    "canvas",
    "trading",
    "stock",
    "crypto",
    "technical-analysis",
    "MACD",
    "RSI",
    "KDJ",
    "BOLL",
    "MA",
    "EMA"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
